{
  "name": "fifa-matchmate-ai-root",
  "version": "1.0.0",
  "description": "Root configuration and run scripts for FIFA MatchMate AI",
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "start:frontend": "npm run dev --prefix frontend",
    "start:backend": "cd backend && python -m uvicorn main:app --reload --port 8000",
    "test:frontend": "npm run test --prefix frontend",
    "test:backend": "cd backend && pytest"
  },
  "dependencies": {},
  "devDependencies": {}
}
